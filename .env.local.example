# 复制为 .env.local 并填写真实值（.env.local 已 gitignore，勿提交）
#
#   cp .env.local.example .env.local
#
# WordPress 应用密码：后台 → 用户 → 个人资料 → 应用密码

# 当前使用的站点（本地调试 / 上线前改生产 URL）
WP_SITE_URL=http://molsimulx.local/

# REST API 发布账号
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Kadence 母版文章 ID（克隆区块骨架，仅替换第一个「自定义 HTML」块）
WP_TEMPLATE_POST_ID=650

# 可选：覆盖默认草稿行为（正式环境也建议保持 draft，人工后台发布）
# WP_POST_STATUS=draft
