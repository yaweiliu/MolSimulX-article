LAMMPS (4 Jul 2026 - Development - patch_4Jul2026-178-gc4fe7a5bcf)
# =============================================================================
# 两板间液体：上板机械控压（恒力）+ 流体 NVT
# -----------------------------------------------------------------------------
# 体系约定（与 data.lmp / Packmol 一致）：
#   molecule 1 = 上板（upper）  molecule 2 = 下板（lower）
#   type 1 = 墙碳 C    type 2 = 水 H (Hw)    type 3 = 水 O (Ow)
# 控压思路：对上板施加沿 −z 的恒力 F = −P·A，等效目标压力 mypress；
#           下板不积分 → 位置固定；流体用 NVT。
# =============================================================================

# ----- 可调参数 -----
variable        myrand          equal   49303           # 速度初始化随机种子
variable        mytemp          equal   300.0           # 流体目标温度 [K]
variable        mypress         equal   1.0             # 上板目标压力 [atm]

# ----- 基本设置 -----
units           real
boundary        p p p                                   # x/y/z 均周期；z 向靠两板夹持

atom_style      full
bond_style      harmonic
angle_style     harmonic
special_bonds   amber                                   # 1-2/1-3/1-4 权重与 AMBER/GAFF 一致

pair_style      lj/cut/coul/long  10.0  10.0             # LJ + 截断库仑；无长程 kspace
pair_modify     mix arithmetic  shift yes
kspace_style    pppm  1.0e-4                            # 若改用长程静电势，取消注释并调整 pair_style

read_data       data.lmp
Reading data file ...
  orthogonal box = (-16.8291 -16.6565 -50) to (16.8291 16.6565 50)
  2 by 1 by 4 MPI processor grid
  reading atoms ...
  7792 atoms
  scanning bonds ...
  1 = max bonds/atom
  scanning angles ...
  1 = max angles/atom
  orthogonal box = (-16.8291 -16.6565 -50) to (16.8291 16.6565 50)
  2 by 1 by 4 MPI processor grid
  reading bonds ...
  4000 bonds
  reading angles ...
  2000 angles
Finding 1-2 1-3 1-4 neighbors ...
  special bond factors lj:    0        0        0.5     
  special bond factors coul:  0        0        0.8333333333333334
     2 = max # of 1-2 neighbors
     1 = max # of 1-3 neighbors
     1 = max # of 1-4 neighbors
     2 = max # of special neighbors
  special bonds CPU = 0.000 seconds
  read_data CPU = 0.036 seconds

# LJ 参数：ε [kcal/mol]，σ [Å]（同种；异种由 arithmetic 混合）
pair_coeff      1  1    0.105000    3.430851            # C（墙）
pair_coeff      2  2    0.000000    1.000000            # Hw（SPC/E 氢，ε=0）
pair_coeff      3  3    0.155300    3.166000            # Ow（SPC/E 氧）

neighbor        2.0  bin
neigh_modify    delay 0  every 1  check yes

timestep        1.0                                     # [fs]，units real

# ----- 分组 -----
group           upper   molecule  1                     # 上板
896 atoms in group upper
group           lower   molecule  2                     # 下板（本脚本不积分 → 固定）
896 atoms in group lower
group           wall    molecule  1 2                   # 上下板合计
1792 atoms in group wall
group           fluid   type      2 3                   # 水（H + O）
6000 atoms in group fluid

# ----- 能量最小化（墙先冻住，避免板被推散）-----
fix             freeze  wall  setforce  0 0 0
minimize        0.0  1.0e-8  1000  100000
